    "statuses": [
      {
        "id": "N/A",
        "meaning": "Not applicable — this team has nothing to do on this item",
        "color_bg": "#D9D9D9",
        "color_fg": "#595959",
        "rollup_priority": 8
      },
      {
        "id": "N/S",
        "meaning": "Not started — work is known and will be picked up later",
        "color_bg": "#FFD7A8",
        "color_fg": "#9C5700",
        "rollup_priority": 6
      },
      {
        "id": "Discovery",
        "meaning": "Work has started but is still being explored / not yet sized",
        "color_bg": "#FFF2CC",
        "color_fg": "#7F6000",
        "rollup_priority": 5
      },
      {
        "id": "Ready",
        "meaning": "Estimated and ready to start — waiting for scheduling",
        "color_bg": "#FFF2CC",
        "color_fg": "#006100",
        "rollup_priority": 4
      },
      {
        "id": "Constrained",
        "meaning": "Work is known and sized but team lacks capacity to start",
        "color_bg": "#E4D7F5",
        "color_fg": "#5B2C87",
        "rollup_priority": 3
      },
      {
        "id": "Doing",
        "meaning": "Work is actively in progress",
        "color_bg": "#BDD7EE",
        "color_fg": "#1F3864",
        "rollup_priority": 2
      },
      {
        "id": "Done",
        "meaning": "Work is complete",
        "color_bg": "#C6EFCE",
        "color_fg": "#006100",
        "rollup_priority": 7
      },
      {
        "id": "Blocked",
        "meaning": "Work cannot progress due to an external dependency",
        "color_bg": "#FFC7CE",
        "color_fg": "#9C0006",
        "rollup_priority": 1
      }
    ],
    "rollup": {
      "strategy": "worst-status-wins",
      "description": "Each parent initiative's status per team is computed from its children. For each team column, the parent takes the child status with the lowest (most-urgent) rollup_priority value. Ties broken by order below.",
      "priority_order_most_to_least_urgent": [
        "Blocked",
        "Doing",
        "Constrained",
        "Ready",
        "Discovery",
        "N/S",
        "Done",
        "N/A"
      ],
      "rationale": {
        "Blocked": "Highest urgency — needs external unblocking.",
        "Doing": "Active work — visibility priority.",
        "Constrained": "Work ready but no capacity — a capacity signal worth surfacing.",
        "Ready": "Sized and ready to start — next in queue.",
        "Discovery": "Exploratory — not yet sized.",
        "N/S": "Known backlog.",
        "Done": "Shown only if no other live work exists.",
        "N/A": "Lowest — only shown if every child is N/A."
      }
    }
  },
